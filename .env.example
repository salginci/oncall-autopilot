# === Required for Hackathon ===

# Qwen Cloud API Key (sign up at https://qwencloud.com)
QWEN_API=sk-...

# GitHub Personal Access Token (classic token with `repo` scope)
# Used for: detecting commits, reading diffs, pushing revert commits
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# === Alibaba Cloud (will be provisioned with hackathon credits) ===

# Redis connection (ApsaraDB Redis instance)
REDIS_URL=redis://your-instance.aliyuncs.com:6379

# Simple Log Service endpoint
SLS_ENDPOINT=your-project.log.aliyuncs.com
SLS_ACCESS_KEY_ID=...
SLS_ACCESS_KEY_SECRET=...

# Alibaba Cloud ECS credentials (for deployment)
ALIBABA_ACCESS_KEY_ID=...
ALIBABA_ACCESS_KEY_SECRET=...

# === Demo Configuration ===

# GitHub repo to monitor for demo (this repo itself)
DEMO_REPO=salginci/oncall-autopilot

# Demo service URL (on ECS)
DEMO_SERVICE_URL=http://localhost:3000

# Polling interval for agent monitoring (seconds)
AGENT_POLL_INTERVAL=5

# Alert thresholds
ERROR_RATE_THRESHOLD=0.10
LATENCY_THRESHOLD_MS=500
